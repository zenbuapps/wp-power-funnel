// WorkflowRules CRUD 資料模型
// 基於 WordPress CPT (Custom Post Type) 架構
// wp_posts 儲存主資料，wp_postmeta 儲存擴充欄位（nodes、trigger_point）

// =============================================================
// Enums（對應 PHP Shared\Enums）
// =============================================================

Enum workflow_rule_status {
  draft    [note: '草稿']
  publish  [note: '已發布']
  trash    [note: '已刪除']

  Note: '對應 EWorkflowRuleStatus'
}

Enum trigger_point {
  "pf/trigger/registration_created"  [note: '用戶報名後']

  Note: '對應 ETriggerPoint，值帶有 pf/trigger/ 前綴'
}

Enum node_module {
  email          [note: '傳送 Email']
  sms            [note: '傳送 SMS']
  line           [note: '傳送 LINE 訊息']
  webhook        [note: '發送 Webhook 通知']
  wait           [note: '等待']
  wait_until     [note: '等待至']
  time_window    [note: '等待至時間窗口']
  yes_no_branch  [note: '是/否分支']
  tag_user       [note: '標籤用戶']

  Note: '對應 ENode'
}

Enum node_type {
  send_message  [note: '傳送訊息類（email, sms, line, webhook）']
  action        [note: '動作類（wait, wait_until, time_window, yes_no_branch, tag_user）']

  Note: '對應 ENodeType'
}

Enum workflow_status {
  running    [note: '進行中']
  completed  [note: '已完成']
  failed     [note: '失敗']

  Note: '對應 EWorkflowStatus'
}

// =============================================================
// Tables
// =============================================================

// ----- WorkflowRule（設計時：規則模板）-----
// 對應 CPT pf_workflow_rule，儲存在 wp_posts + wp_postmeta
Table workflow_rules {
  id             integer         [pk, increment, note: 'wp_posts.ID']
  title          varchar         [not null, note: 'wp_posts.post_title — WorkflowRule 名稱']
  status         workflow_rule_status  [not null, default: 'draft', note: 'wp_posts.post_status']
  post_type      varchar         [not null, default: 'pf_workflow_rule', note: 'wp_posts.post_type，固定值']
  date_created   timestamp       [not null, note: 'wp_posts.post_date']
  date_modified  timestamp       [not null, note: 'wp_posts.post_modified']
  author_id      integer         [not null, note: 'wp_posts.post_author — 建立者/修改者 user ID']

  // 以下欄位存在 wp_postmeta 中
  trigger_point  trigger_point   [note: 'wp_postmeta key=trigger_point — 觸發點 hook name']
  nodes          "json[]"        [note: 'wp_postmeta key=nodes — NodeDTO 陣列的 JSON 序列化']

  Note: '''
    WorkflowRule 規則模板（設計時）。
    管理員透過 React Flow 畫布設計節點流程。
    發布後，當觸發點事件發生時，系統會依此模板建立 Workflow 執行實例。
    對應 CPT: pf_workflow_rule
    supports: [title, custom-fields]
    狀態流轉: draft <-> publish（可雙向切換）
    刪除策略: 任何狀態皆可直接刪除（force=true 永久刪除）
  '''

  indexes {
    post_type [name: 'idx_post_type']
    status    [name: 'idx_status']
    (post_type, status) [name: 'idx_type_status']
  }
}

// ----- NodeDTO（Value Object：節點資料）-----
// 非獨立資料表，以 JSON 陣列形式存在 workflow_rules.nodes (wp_postmeta) 中
// 此處建模為 Table 以明確描述結構
Table node_dtos {
  id                     varchar  [pk, note: '節點唯一 ID（如 node_1）']
  workflow_rule_id       integer  [not null, note: '所屬 WorkflowRule ID']
  node_definition_id     varchar  [not null, note: '節點定義 ID，對應 ENode value（如 email, wait）']
  params                 json     [note: '節點參數 key-value（依節點類型不同）']
  match_callback         json     [note: '條件匹配 callback，預設 __return_true']
  match_callback_params  json     [note: 'match_callback 接受的參數']

  Note: '''
    NodeDTO Value Object。
    非獨立資料表，以 JSON 陣列形式嵌入 workflow_rules.nodes meta 中。
    對應 PHP: Contracts\DTOs\NodeDTO
    每個 NodeDTO 代表流程中的一個執行節點。
    node_definition_id 對應已註冊的 NodeDefinition（透過 power_funnel/workflow_rule/node_definitions filter）。
  '''
}

// ----- Workflow（執行時：規則實例）-----
// 對應 CPT pf_workflow，由 WorkflowRule 觸發後建立
Table workflows {
  id               integer          [pk, increment, note: 'wp_posts.ID']
  name             varchar          [not null, note: 'wp_posts.post_title']
  status           workflow_status  [not null, default: 'running', note: 'wp_posts.post_status（自訂狀態）']
  post_type        varchar          [not null, default: 'pf_workflow', note: 'wp_posts.post_type，固定值']
  date_created     timestamp        [not null, note: 'wp_posts.post_date']
  date_modified    timestamp        [not null, note: 'wp_posts.post_modified']

  // 以下欄位存在 wp_postmeta 中
  workflow_rule_id integer          [not null, note: 'wp_postmeta key=workflow_rule_id — 來源 WorkflowRule ID']
  trigger_point    varchar          [not null, note: 'wp_postmeta key=trigger_point — 觸發點 hook name']
  nodes            "json[]"         [note: 'wp_postmeta key=nodes — 執行時的 NodeDTO 陣列快照']
  context          json             [note: 'wp_postmeta key=context_callable_set — 執行上下文']
  results          "json[]"         [note: 'wp_postmeta key=results — WorkflowResultDTO 陣列']

  Note: '''
    Workflow 執行實例（執行時）。
    由 WorkflowRule 的 trigger_point 事件觸發時自動建立。
    複製 WorkflowRule 的 nodes 作為執行快照，逐節點執行。
    對應 CPT: pf_workflow
    狀態流轉: running -> completed | failed
    結果碼: 200=成功, 301=跳過（match_callback 不符）, 500=失敗
  '''

  indexes {
    workflow_rule_id [name: 'idx_workflow_rule_id']
    status           [name: 'idx_workflow_status']
  }
}

// ----- WordPress Users（參考：管理員）-----
// WordPress 內建 wp_users 表，此處僅列出 WorkflowRules 相關欄位
Table wp_users {
  id            integer  [pk, increment, note: 'wp_users.ID']
  display_name  varchar  [not null, note: 'wp_users.display_name']

  Note: '''
    WordPress 內建使用者表（簡化版）。
    僅列出 WorkflowRules 功能相關的欄位。
    管理員需具備 manage_options capability。
  '''
}

// =============================================================
// Relationships
// =============================================================

// WorkflowRule 由管理員建立/修改
Ref: workflow_rules.author_id > wp_users.id

// NodeDTO 嵌入在 WorkflowRule 中（邏輯關聯，實際為 JSON 嵌入）
Ref: node_dtos.workflow_rule_id > workflow_rules.id

// Workflow 由 WorkflowRule 觸發建立（一個 Rule 可產生多個 Workflow 實例）
Ref: workflows.workflow_rule_id > workflow_rules.id
